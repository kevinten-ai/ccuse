#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
PROFILE_DIR="${PROFILE_DIR:-$CLAUDE_DIR/profiles}"
SETTINGS_FILE="${SETTINGS_FILE:-$CLAUDE_DIR/settings.json}"
BACKUP_SUFFIX="${BACKUP_SUFFIX:-.bak}"

usage() {
  cat <<'USAGE'
Usage:
  ccuse claude          Switch to native Claude profile
  ccuse glm             Switch to GLM (Zhipu AI) profile
  ccuse kimi            Switch to Kimi (Moonshot AI) profile
  ccuse init-claude     Save current settings.json as claude profile
  ccuse init-glm        Create a GLM profile template
  ccuse init-kimi       Create a Kimi profile template
  ccuse list            List all available profiles
  ccuse show            Show current Claude Code configuration
  ccuse edit <name>     Edit a profile file

Environment overrides:
  CLAUDE_DIR, PROFILE_DIR, SETTINGS_FILE, BACKUP_SUFFIX

Examples:
  ccuse init-glm        # Create GLM profile, opens editor to set API key
  ccuse glm             # Switch to GLM profile
  ccuse show            # View current configuration
  ccuse list            # See all available profiles
USAGE
}

ensure_profiles_dir() {
  mkdir -p "$PROFILE_DIR"
}

backup_settings() {
  if [[ -f "$SETTINGS_FILE" ]]; then
    cp "$SETTINGS_FILE" "${SETTINGS_FILE}${BACKUP_SUFFIX}"
  fi
}

apply_profile() {
  local name="$1"
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi
  backup_settings
  cp "$file" "$SETTINGS_FILE"
  echo "Switched to profile: $name"
}

init_claude() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/claude.json"
  if [[ -f "$SETTINGS_FILE" ]]; then
    cp "$SETTINGS_FILE" "$file"
    echo "Saved current settings to: $file"
  else
    printf '{\n}\n' > "$file"
    echo "Created empty profile: $file"
  fi
  echo ""
  echo "This profile uses your native Claude API key from Anthropic."
  echo "No additional configuration needed."
}

init_glm() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/glm.json"
  if [[ -f "$file" ]]; then
    echo "Profile already exists: $file" >&2
    exit 1
  fi
  cat > "$file" <<'JSON'
{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_ZHIPU_API_KEY",
    "ANTHROPIC_BASE_URL": "https://open.bigmodel.cn/api/anthropic",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-4.7-FlashX"
  }
}
JSON
  echo "Created template: $file"
  echo ""
  echo "=========================================="
  echo "  Next Step: Set your Zhipu API Key"
  echo "=========================================="
  echo ""
  echo "1. Get your API key from: https://open.bigmodel.cn/iframe/login"
  echo "2. Replace YOUR_ZHIPU_API_KEY in the profile file"
  echo ""
  echo "Available models:"
  echo "  - GLM-5            (Latest flagship, coding aligned with Claude Opus 4.5)"
  echo "  - GLM-4.7          (High intelligence, better coding & aesthetics)"
  echo "  - GLM-4.7-FlashX   (Lightweight, fast, cost-effective)"
  echo ""
  echo "3. Then run: ccuse glm"
  echo ""
  edit_file "$file"
}

init_kimi() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/kimi.json"
  if [[ -f "$file" ]]; then
    echo "Profile already exists: $file" >&2
    exit 1
  fi
  cat > "$file" <<'JSON'
{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_KIMI_API_KEY",
    "ANTHROPIC_BASE_URL": "https://api.moonshot.cn/v1",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "kimi-k2.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k2.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2-turbo-preview"
  }
}
JSON
  echo "Created template: $file"
  echo ""
  echo "=========================================="
  echo "  Next Step: Set your Kimi API Key"
  echo "=========================================="
  echo ""
  echo "1. Get your API key from: https://platform.moonshot.cn/console/api-keys"
  echo "2. Replace YOUR_KIMI_API_KEY in the profile file"
  echo ""
  echo "Available models:"
  echo "  - kimi-k2.5          (Latest, most intelligent, 256k context)"
  echo "  - kimi-k2-0905-preview (Enhanced agentic coding)"
  echo "  - kimi-k2-turbo-preview (High speed, 60-100 tokens/s)"
  echo ""
  echo "3. Then run: ccuse kimi"
  echo ""
  edit_file "$file"
}

edit_file() {
  local file="$1"
  if [[ -n "${EDITOR:-}" ]]; then
    echo "Opening $file with $EDITOR..."
    $EDITOR "$file"
  elif command -v code &>/dev/null; then
    echo "Opening $file with VS Code..."
    code "$file"
  elif command -v nano &>/dev/null; then
    echo "Opening $file with nano..."
    nano "$file"
  else
    echo "File location: $file"
    echo "Please edit it manually."
  fi
}

list_profiles() {
  ensure_profiles_dir
  echo "Available profiles in $PROFILE_DIR:"
  echo ""
  local current=""
  if [[ -f "$SETTINGS_FILE" ]]; then
    current=$(basename "$(readlink -f "$SETTINGS_FILE" 2>/dev/null || echo "$SETTINGS_FILE")" .json 2>/dev/null || echo "")
  fi
  for f in "$PROFILE_DIR"/*.json; do
    if [[ -f "$f" ]]; then
      local name=$(basename "$f" .json)
      if [[ "$name" == "$current" ]]; then
        echo "  * $name (current)"
      else
        echo "    $name"
      fi
    fi
  done
  echo ""
  echo "Run 'ccuse <name>' to switch to a profile."
}

show_config() {
  echo "Current Claude Code Configuration"
  echo "=================================="
  echo ""
  echo "Settings file: $SETTINGS_FILE"
  echo ""
  if [[ ! -f "$SETTINGS_FILE" ]]; then
    echo "No settings file found."
    return
  fi
  echo "Configuration:"
  echo ""
  # Parse and display key environment variables
  if command -v python3 &>/dev/null; then
    python3 -c "
import json
import sys
try:
    with open('$SETTINGS_FILE', 'r') as f:
        data = json.load(f)
    env = data.get('env', {})
    if not env:
        print('  (empty configuration)')
    else:
        # Show key configurations, mask API keys
        for key, value in sorted(env.items()):
            if 'KEY' in key.upper() or 'TOKEN' in key.upper():
                # Mask API key
                if len(str(value)) > 8:
                    masked = str(value)[:4] + '****' + str(value)[-4:]
                else:
                    masked = '****'
                print(f'  {key}: {masked}')
            else:
                print(f'  {key}: {value}')
except Exception as e:
    print(f'  Error reading config: {e}')
    sys.exit(1)
"
  else
    # Fallback: just cat the file
    cat "$SETTINGS_FILE"
  fi
  echo ""
  echo "=================================="
  echo "Run 'ccuse edit' to modify, 'ccuse list' to see profiles."
}

case "${1:-}" in
  claude) apply_profile "claude" ;;
  glm) apply_profile "glm" ;;
  kimi) apply_profile "kimi" ;;
  init-claude) init_claude ;;
  init-glm) init_glm ;;
  init-kimi) init_kimi ;;
  list|ls) list_profiles ;;
  show|config|current) show_config ;;
  edit)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: ccuse edit <profile-name>" >&2
      exit 1
    fi
    file="$PROFILE_DIR/${2}.json"
    if [[ ! -f "$file" ]]; then
      echo "Profile not found: $file" >&2
      exit 1
    fi
    edit_file "$file"
    ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown command: $1" >&2; usage; exit 2 ;;
esac
