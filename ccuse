project_command() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    echo "Usage: ccuse project <profile-name>|rm|show" >&2
    exit 1
  fi
  case "$sub" in
    rm|remove|reset) project_remove_profile ;;
    show|current) project_show_config ;;
    *) project_apply_profile "$sub" ;;
  esac
}

profile_env_exports() {
  local file="$1"
  local clear_keys=()
  while IFS= read -r key; do
    clear_keys+=("$key")
  done < <(provider_env_keys)
  local py=""
  if py="$(python_cmd)"; then
    "$py" -c "
import json, re, sys, shlex
with open(sys.argv[1], 'r', encoding='utf-8-sig') as f:
    data = json.load(f)
keys_to_clear = sys.argv[2:]
env = data.get('env', {})
if not isinstance(env, dict):
    print('Error: profile env must be a JSON object', file=sys.stderr)
    sys.exit(1)
for key, value in sorted(env.items()):
    if not re.fullmatch(r'[A-Za-z_][A-Za-z0-9_]*', str(key)):
        print(f'Error: invalid environment variable name: {key}', file=sys.stderr)
        sys.exit(1)
for key in keys_to_clear:
    print(f'unset {key}')
for key, value in sorted(env.items()):
    print(f'export {key}={shlex.quote(str(value))}')
" "$file" "${clear_keys[@]}"
  else
    echo "Error: python3 or python is required to parse profile JSON" >&2
    exit 1
  fi
}

local_apply_profile() {
  local name="$1"
  validate_profile_name "$name"
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi

  profile_env_exports "$file"
  echo ""
  echo "# Run this command to apply these variables to your current shell:"
  echo "# eval \"\$(ccuse local $name)\""
}

local_remove_profile() {
  provider_env_keys | while IFS= read -r key; do
    echo "unset $key"
  done
  echo ""
  echo "# Run this command to clear these variables from your current shell:"
  echo "# eval \"\$(ccuse local rm)\""
}

local_show_config() {
  echo "Current Shell Session - Claude Code Environment Variables"
  echo "========================================================="
  echo ""
  local has_vars=false
  local vars="ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN API_TIMEOUT_MS CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL"
  for var in $vars; do
    if [[ -n "${!var:-}" ]]; then
      has_vars=true
      if [[ "$var" == *"KEY"* || "$var" == *"TOKEN"* ]]; then
        local value="${!var}"
        if [[ ${#value} -gt 8 ]]; then
          echo "  $var: ${value:0:4}****${value: -4}"
        else
          echo "  $var: ****"
        fi
      else
        echo "  $var: ${!var}"
      fi
    fi
  done
  if [[ "$has_vars" == "false" ]]; then
    echo "  (no Claude-specific environment variables set)"
  fi
  echo ""
  echo "========================================================="
  echo "Run 'eval \"\$(ccuse local <profile>)\"' to load a profile into this session."
}

start_session() {
  local name="${1:-}"
  shift || true
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse start <profile-name> [options]" >&2
    echo "  Options:" >&2
    echo "    -c, --continue    Resume last conversation" >&2
    exit 1
  fi
  validate_profile_name "$name"

  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi

  echo "Loading profile env vars: $name"
  local exports
  exports="$(profile_env_exports "$file")"
  eval "$exports"
  echo "Launching Claude Code..."
  echo ""

  local claude_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c|--continue) claude_args+=(--continue) ;;
      *) claude_args+=("$1") ;;
    esac
    shift
  done

  if command -v claude &>/dev/null; then
    claude "${claude_args[@]}"
  else
    echo "Error: 'claude' command not found." >&2
    echo "Please install Claude Code CLI first." >&2
    exit 1
  fi
}

case "${1:-}" in
  claude) apply_profile "claude" ;;
  glm) apply_profile "glm" ;;
  kimi) apply_profile "kimi" ;;
  minimax) apply_profile "minimax" ;;
  global|g) global_command "${2:-}" ;;
  project|p) project_command "${2:-}" ;;
  start|s) start_session "${2:-}" "${@:3}" ;;
  cc) shift; start_session "claude" "$@" ;;
  ck) shift; start_session "kimi" "$@" ;;
  cg) shift; start_session "glm" "$@" ;;
  cm) shift; start_session "minimax" "$@" ;;
  init-claude) init_claude ;;
  init-glm) init_glm ;;
  init-kimi) init_kimi ;;
  init-minimax) init_minimax ;;
  list|ls) list_profiles ;;
  remove|rm) remove_profile "${2:-}" ;;
  delete) remove_profile "${2:-}" ;;
  show|config|current) show_config ;;
  doctor|status) doctor ;;
  edit)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: ccuse edit <profile-name>" >&2
      exit 1
    fi
    validate_custom_profile_name "$2"
    ensure_profiles_dir
    file="$PROFILE_DIR/${2}.json"
    if [[ ! -f "$file" ]]; then
      printf '{\n  "env": {}\n}\n' > "$file"
      echo "Created profile: $file"
    fi
    edit_file "$file"
    ;;
  local)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: ccuse local <profile-name>|rm|show" >&2
      exit 1
    fi
    case "${2:-}" in
      rm|remove|reset) local_remove_profile ;;
      show|current) local_show_config ;;
      *) local_apply_profile "$2" ;;
    esac
    ;;
  -h|--help|help|"") usage ;;
  *)
    validate_profile_name "$1"
    if [[ -f "$PROFILE_DIR/${1}.json" ]]; then
      apply_profile "$1"
    else
      echo "Unknown command: $1" >&2
      usage
      exit 2
    fi
    ;;
esac
