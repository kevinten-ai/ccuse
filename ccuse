edit_file() {
  local file="$1"
  if [[ -n "${EDITOR:-}" ]]; then
    echo "Opening $file with $EDITOR..."
    $EDITOR "$file"
  elif command -v code &>/dev/null; then
    echo "Opening $file with VS Code..."
    code "$file"
  elif command -v nano &>/dev/null; then
    echo "Opening $file with nano..."
    nano "$file"
  else
    echo "File location: $file"
    echo "Please edit it manually."
  fi
}

list_profiles() {
  ensure_profiles_dir
  echo "Available profiles in $PROFILE_DIR:"
  echo ""
  local current=""
  local active_profile=""
  if [[ -f "$SETTINGS_FILE" ]]; then
    current=$(basename "$(readlink -f "$SETTINGS_FILE" 2>/dev/null || echo "$SETTINGS_FILE")" .json 2>/dev/null || echo "")
    # Try to detect active profile by comparing content
    for f in "$PROFILE_DIR"/*.json; do
      if [[ -f "$f" ]]; then
        if diff -q "$SETTINGS_FILE" "$f" >/dev/null 2>&1; then
          active_profile=$(basename "$f" .json)
          break
        fi
      fi
    done
  fi

  local count=0
  for f in "$PROFILE_DIR"/*.json; do
    if [[ -f "$f" ]]; then
      ((count++)) || true
      local name=$(basename "$f" .json)
      if [[ "$name" == "$active_profile" ]]; then
        echo "  * $name (active)"
      else
        echo "    $name"
      fi
    fi
  done

  if [[ $count -eq 0 ]]; then
    echo "  (no profiles found)"
    echo ""
    echo "Run 'ccuse init-<provider>' to create a profile."
  else
    echo ""
    echo "Run 'ccuse global <name>' for global, 'ccuse project <name>' for this repo, or 'ccuse start <name>' for one launch."
  fi
}

remove_profile() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse remove <profile-name>" >&2
    exit 1
  fi
  validate_profile_name "$name"

  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Profile not found: $file" >&2
    exit 1
  fi

  # Check if this is the currently active profile
  local is_active=false
  if [[ -f "$SETTINGS_FILE" ]] && diff -q "$SETTINGS_FILE" "$file" >/dev/null 2>&1; then
    is_active=true
  fi

  echo "Removing profile: $name"
  if [[ "$is_active" == "true" ]]; then
    echo "Warning: This is your currently active profile!"
  fi
  read -rp "Are you sure? [y/N] " answer
  if [[ "$answer" =~ ^[Yy]$ ]]; then
    rm "$file"
    echo "Profile removed: $name"
    if [[ "$is_active" == "true" ]]; then
      echo ""
      echo "Note: Your current settings.json still uses this configuration."
      echo "Switch to another profile with 'ccuse <name>' to change."
    fi
  else
    echo "Cancelled."
    exit 0
  fi
}

show_config() {
  echo "Current Claude Code Configuration"
  echo "=================================="
  echo ""
  echo "Settings file: $SETTINGS_FILE"
  echo ""
  if [[ ! -f "$SETTINGS_FILE" ]]; then
    echo "No settings file found."
    return
  fi
  echo "Configuration:"
  echo ""
  # Parse and display key environment variables
  local py=""
  if py="$(python_cmd)"; then
    "$py" -c "
import json
import sys
try:
    with open(sys.argv[1], 'r') as f:
        data = json.load(f)
    env = data.get('env', {})
    if not env:
        print('  (empty configuration)')
    else:
        # Show key configurations, mask API keys
        for key, value in sorted(env.items()):
            if 'KEY' in key.upper() or 'TOKEN' in key.upper():
                # Mask API key
                if len(str(value)) > 8:
                    masked = str(value)[:4] + '****' + str(value)[-4:]
                else:
                    masked = '****'
                print(f'  {key}: {masked}')
            else:
                print(f'  {key}: {value}')
except Exception as e:
    print(f'  Error reading config: {e}')
    sys.exit(1)
" "$SETTINGS_FILE"
  else
    # Fallback: just cat the file
    cat "$SETTINGS_FILE"
  fi
  echo ""
  echo "=================================="
  echo "Run 'ccuse edit' to modify, 'ccuse list' to see profiles."
}

active_profile_name() {
  local target_file="$1"
  if [[ ! -f "$target_file" ]]; then
    return 1
  fi
  for f in "$PROFILE_DIR"/*.json; do
    if [[ -f "$f" ]] && diff -q "$target_file" "$f" >/dev/null 2>&1; then
      basename "$f" .json
      return 0
    fi
  done
  return 1
}

doctor() {
  echo "ccuse doctor"
  echo "============"
  echo ""

  if command -v claude &>/dev/null; then
    echo "Claude Code CLI: found ($(command -v claude))"
  else
    echo "Claude Code CLI: missing"
  fi

  local py=""
  if py="$(python_cmd)"; then
    echo "Python JSON parser: found ($py)"
  else
    echo "Python JSON parser: missing (needed for local/start commands)"
  fi

  echo ""
  echo "Global config:"
  echo "  CLAUDE_DIR: $CLAUDE_DIR"
  echo "  PROFILE_DIR: $PROFILE_DIR"
  echo "  SETTINGS_FILE: $SETTINGS_FILE"
  if [[ -f "$SETTINGS_FILE" ]]; then
    local active=""
    active="$(active_profile_name "$SETTINGS_FILE" || true)"
    if [[ -n "$active" ]]; then
      echo "  Active global profile: $active"
    else
      echo "  Active global profile: custom/unknown"
    fi
  else
    echo "  Active global profile: none"
  fi

  echo ""
  echo "Profiles:"
  if [[ -d "$PROFILE_DIR" ]]; then
    local count=0
    for f in "$PROFILE_DIR"/*.json; do
      if [[ -f "$f" ]]; then
        ((count++)) || true
        echo "  - $(basename "$f" .json)"
      fi
    done
    if [[ $count -eq 0 ]]; then
      echo "  (none)"
      echo "  Next: ccuse init-claude, ccuse init-kimi, ccuse init-glm, or ccuse init-minimax"
    fi
  else
    echo "  Profile directory does not exist yet."
    echo "  Next: ccuse init-claude"
  fi

  echo ""
  echo "Project config:"
  echo "  PROJECT_SETTINGS_FILE: $PROJECT_SETTINGS_FILE"
  if [[ -f "$PROJECT_SETTINGS_FILE" ]]; then
    local project_active=""
    project_active="$(active_profile_name "$PROJECT_SETTINGS_FILE" || true)"
    if [[ -n "$project_active" ]]; then
      echo "  Active project profile: $project_active"
    else
      echo "  Active project profile: custom/unknown"
    fi
  else
    echo "  Active project profile: none"
  fi

  echo ""
  echo "Session env:"
  local has_vars=false
  local var=""
  while IFS= read -r var; do
    if [[ -n "${!var:-}" ]]; then
      has_vars=true
      if [[ "$var" == *"KEY"* || "$var" == *"TOKEN"* ]]; then
        echo "  $var: ****"
      else
        echo "  $var: ${!var}"
      fi
    fi
  done < <(provider_env_keys)
  if [[ "$has_vars" == "false" ]]; then
    echo "  (no provider env vars set)"
  fi

  echo ""
  echo "Common next steps:"
  echo "  Native Claude globally: ccuse init-claude && ccuse global claude"
  echo "  Try Kimi once:          ccuse start kimi -c"
  echo "  Persist Kimi here:      ccuse project kimi"
}

project_apply_profile() {
  local name="$1"
  validate_profile_name "$name"
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi
  if [[ "$name" == "claude" ]] && grep -q '"ANTHROPIC_BASE_URL"' "$file" 2>/dev/null; then
    echo "Warning: claude profile contains ANTHROPIC_BASE_URL (third-party provider config)." >&2
    echo "Run 'ccuse init-claude' to recreate a clean Claude profile." >&2
    read -rp "Apply anyway? [y/N] " answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Cancelled."
      exit 0
    fi
  fi

  mkdir -p "$(dirname "$PROJECT_SETTINGS_FILE")"
  if [[ -f "$PROJECT_SETTINGS_FILE" ]]; then
    cp "$PROJECT_SETTINGS_FILE" "${PROJECT_SETTINGS_FILE}${BACKUP_SUFFIX}"
  fi
  cp "$file" "$PROJECT_SETTINGS_FILE"
  echo "Applied project profile: $name"
  echo "Project settings: $PROJECT_SETTINGS_FILE"
}

project_remove_profile() {
  if [[ ! -f "$PROJECT_SETTINGS_FILE" ]]; then
    echo "No project configuration found: $PROJECT_SETTINGS_FILE" >&2
    exit 1
  fi
  rm "$PROJECT_SETTINGS_FILE"
  echo "Removed project configuration: $PROJECT_SETTINGS_FILE"
}

