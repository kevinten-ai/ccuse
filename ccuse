#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
PROFILE_DIR="${PROFILE_DIR:-$CLAUDE_DIR/profiles}"
SETTINGS_FILE="${SETTINGS_FILE:-$CLAUDE_DIR/settings.json}"
BACKUP_SUFFIX="${BACKUP_SUFFIX:-.bak}"
PROJECT_CLAUDE_DIR="${PROJECT_CLAUDE_DIR:-.claude}"
PROJECT_SETTINGS_FILE="${PROJECT_SETTINGS_FILE:-$PROJECT_CLAUDE_DIR/settings.json}"

usage() {
  cat <<'USAGE'
Usage:
  ccuse claude             Switch to native Claude profile (modifies settings.json)
  ccuse glm                Switch to GLM (Zhipu AI) profile (modifies settings.json)
  ccuse kimi               Switch to Kimi (Moonshot AI) profile (modifies settings.json)
  ccuse minimax            Switch to MiniMax profile (modifies settings.json)
  ccuse global <profile>   Explicit global profile switch
  ccuse g <profile>        Alias for global
  ccuse local <profile>    Output shell exports for a profile (eval to apply)
  ccuse local rm           Output shell unsets to clear session env vars
  ccuse local show         Show current shell session env vars
  ccuse project <profile>  Apply profile to current project only
  ccuse project rm         Remove current project profile
  ccuse project show       Show current project profile
  ccuse p <profile>        Alias for project
  ccuse start <profile>    Launch Claude Code with profile env vars
  ccuse s <profile>        Alias for start
  ccuse cc [-c]            Quick start: claude profile + launch
  ccuse ck [-c]            Quick start: kimi profile + launch
  ccuse cg [-c]            Quick start: glm profile + launch
  ccuse cm [-c]            Quick start: minimax profile + launch
  ccuse init-claude        Save current settings.json as claude profile
  ccuse init-glm           Create or reconfigure a GLM profile
  ccuse init-kimi          Create or reconfigure a Kimi profile
  ccuse init-minimax       Create or reconfigure a MiniMax profile
  ccuse list               List all available profiles
  ccuse ls                 Alias for list
  ccuse show               Show current Claude Code configuration
  ccuse config             Alias for show
  ccuse doctor             Check setup, profiles, and active scopes
  ccuse edit <name>        Edit a profile file
  ccuse remove <name>      Remove a profile
  ccuse rm <name>          Alias for remove
  ccuse <profile>          Switch to a custom profile from PROFILE_DIR

Environment overrides:
  CLAUDE_DIR, PROFILE_DIR, SETTINGS_FILE, BACKUP_SUFFIX
  PROJECT_CLAUDE_DIR, PROJECT_SETTINGS_FILE

Examples:
  ccuse init-claude        # Save native Claude Code account/subscription profile
  ccuse init-kimi          # Create or reconfigure Kimi profile
  ccuse start kimi -c      # Try Kimi once and resume the last conversation
  ccuse project kimi       # Persist Kimi for this repository only
  ccuse global claude      # Make native Claude the global default
  ccuse doctor             # Check current setup
USAGE
}

ensure_profiles_dir() {
  mkdir -p "$PROFILE_DIR"
}

python_cmd() {
  if command -v python3 &>/dev/null; then
    echo "python3"
  elif command -v python &>/dev/null; then
    echo "python"
  else
    return 1
  fi
}

validate_profile_name() {
  local name="$1"
  if [[ -z "$name" || ! "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    echo "Invalid profile name: $name" >&2
    echo "Start with a letter or number; use only letters, numbers, dots, underscores, and hyphens." >&2
    exit 1
  fi
}

is_reserved_profile_name() {
  case "$1" in
    global|g|local|project|p|start|s|cc|ck|cg|cm|list|ls|show|config|current|doctor|status|edit|remove|rm|delete|help)
      return 0
      ;;
    init-claude|init-glm|init-kimi|init-minimax)
      return 0
      ;;
    -h|--help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

validate_custom_profile_name() {
  local name="$1"
  validate_profile_name "$name"
  if is_reserved_profile_name "$name"; then
    echo "Invalid custom profile name: $name" >&2
    echo "That name is reserved for a ccuse command or alias." >&2
    exit 1
  fi
}

provider_env_keys() {
  cat <<'KEYS'
ANTHROPIC_BASE_URL
ANTHROPIC_AUTH_TOKEN
API_TIMEOUT_MS
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC
ANTHROPIC_DEFAULT_OPUS_MODEL
ANTHROPIC_DEFAULT_SONNET_MODEL
ANTHROPIC_DEFAULT_HAIKU_MODEL
KEYS
}

backup_settings() {
  if [[ -f "$SETTINGS_FILE" ]]; then
    cp "$SETTINGS_FILE" "${SETTINGS_FILE}${BACKUP_SUFFIX}"
  fi
}

apply_profile() {
  local name="$1"
  validate_profile_name "$name"
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    case "$name" in
      claude|glm|kimi|minimax) echo "Run: ccuse init-$name" >&2 ;;
      *) echo "Run: ccuse edit $name" >&2 ;;
    esac
    exit 1
  fi
  # Safety check: warn if claude profile contains third-party provider config
  if [[ "$name" == "claude" ]] && grep -q '"ANTHROPIC_BASE_URL"' "$file" 2>/dev/null; then
    echo "Warning: claude profile contains ANTHROPIC_BASE_URL (third-party provider config)." >&2
    echo "This profile may have been saved while another provider was active." >&2
    echo "Run 'ccuse init-claude' to recreate a clean Claude profile." >&2
    read -rp "Apply anyway? [y/N] " answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Cancelled."
      exit 0
    fi
  fi
  backup_settings
  cp "$file" "$SETTINGS_FILE"
  echo "Switched to profile: $name"
}

global_command() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse global <profile-name>" >&2
    exit 1
  fi
  apply_profile "$name"
}

init_claude() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/claude.json"
  local backup_file=""

  # If profile exists, ask user what to do (consistent with init_glm/init_kimi)
  if [[ -f "$file" ]]; then
    echo "Profile already exists: $file"
    read -rp "Do you want to reconfigure it? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      backup_file="${file}.bak.$(date +%Y%m%d%H%M%S)"
      cp "$file" "$backup_file"
      echo "Backup created: $backup_file"
      echo ""
    else
      echo "Keeping existing profile. Use 'ccuse edit claude' to modify it."
      exit 0
    fi
  fi

  if [[ -f "$SETTINGS_FILE" ]]; then
    # Check if current settings contain third-party provider env vars
    if grep -q '"ANTHROPIC_BASE_URL"' "$SETTINGS_FILE" 2>/dev/null; then
      echo "Warning: Current settings.json contains a third-party provider configuration."
      echo "Saving a clean Claude profile by removing provider-specific env variables."
      echo ""
      # Strip provider-specific env vars, keep everything else
      local py=""
      if py="$(python_cmd)"; then
        "$py" -c "
import json, sys
with open(sys.argv[1], 'r', encoding='utf-8-sig') as f:
    data = json.load(f)
env = data.get('env', {})
provider_keys = {
    'ANTHROPIC_AUTH_TOKEN', 'ANTHROPIC_BASE_URL', 'API_TIMEOUT_MS',
    'CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC',
}
for key in list(env.keys()):
    if key in provider_keys or key.startswith('ANTHROPIC_DEFAULT_'):
        del env[key]
if not env:
    data.pop('env', None)
else:
    data['env'] = env
with open(sys.argv[2], 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
" "$SETTINGS_FILE" "$file"
      else
        # Without Python, create a minimal clean profile
        printf '{\n}\n' > "$file"
        echo "Note: Python not found, created minimal profile."
      fi
    else
      cp "$SETTINGS_FILE" "$file"
    fi
    echo "Saved current settings to: $file"
  else
    printf '{\n}\n' > "$file"
    echo "Created empty profile: $file"
  fi
  echo ""
  echo "This profile uses native Claude Code account/subscription mode or your existing Anthropic configuration."
  echo "No third-party provider API key is needed."
}

